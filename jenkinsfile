pipeline {
    agent any 
    environment {
        serviceDir = '../apps' //Путь в workspace до репозитория с сервисом
    }
    stages {
        stage('Condition check') {
            steps {
                script {
                    if(params.DEPLOY == 'install') {
                        def buildScript = load 'vars/build.groovy'
                        buildScript.buildStage()

                        def deploySrcipt = load 'vars/deploy.groovy'
                        deployScript.deployStage()

                        def checkScript = load 'vars/check.groovy'
                        checkScript.checkStage()
                    }
                    if(params.DEPLOY == 'check') {
                        def buildScript = load 'vars/build.groovy'
                        buildScript.buildStage()
                        print('Update repositiry complete')
                    }
                    if(params.DEPLOY == 'delete') {
                        script {
                            withEnv(["PATH=/usr/local/bin:/opt/homebrew/bin:$PATH"]) {
                                withCredentials([file(credentialsId: 'kubeconfig', variable: 'KUBECONFIG')]) {
                                    echo "KUBECONFIG path is: ${env.KUBECONFIG}"
                                    sh script: 'kubectl get nodes --kubeconfig $KUBECONFIG'

                                    dir(serviceDir){
                                        echo "Delete services using Helm..."

                                        sh "helm uninstall prometheus-release -n default"

                                        sh "helm uninstall pushgateway-release -n default"
                                    }
                                }
                            }
                        }
                        echo "✅ Unistall complete"
                    }
                }
            }
        }
    }    
}